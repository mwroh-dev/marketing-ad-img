{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-img/schemas/interview-state.schema.json",
  "title": "Interview state",
  "description": "Criteria-driven interview loop state. Not question-count based; tracks slot resolution until hard blockers clear.",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "mode", "status", "slots"],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "mode": { "type": "string" },
    "status": { "type": "string", "enum": ["in_progress", "ready", "cancelled", "stopped"] },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "state"],
        "properties": {
          "name": { "type": "string" },
          "state": { "type": "string", "enum": ["missing", "insufficient", "filled", "confirmed"] },
          "value": {},
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "answer_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "active_blocker": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["slot", "type"],
          "properties": {
            "slot": { "type": "string" },
            "type": { "type": "string", "enum": ["hard_block", "soft_block"] },
            "question": { "type": "string" }
          }
        }
      ]
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["answer_ref", "slots_updated"],
        "properties": {
          "answer_ref": { "type": "string" },
          "slots_updated": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
