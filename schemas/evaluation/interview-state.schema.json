{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/interview-state.schema.json",
  "title": "Interview state",
  "description": "criteria-driven interview loop state — tracks slot resolution until hard blockers clear",
  "type": "object",
  "required": [
    "run_id",
    "mode",
    "status",
    "slots"
  ],
  "properties": {
    "run_id": {
      "minLength": 1,
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "const": "in_progress",
          "type": "string"
        },
        {
          "const": "ready",
          "type": "string"
        },
        {
          "const": "cancelled",
          "type": "string"
        },
        {
          "const": "stopped",
          "type": "string"
        }
      ]
    },
    "slots": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "name",
          "state"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "state": {
            "anyOf": [
              {
                "const": "missing",
                "type": "string"
              },
              {
                "const": "insufficient",
                "type": "string"
              },
              {
                "const": "filled",
                "type": "string"
              },
              {
                "const": "confirmed",
                "type": "string"
              }
            ]
          },
          "value": {},
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "answer_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "active_blocker": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "slot",
            "type"
          ],
          "properties": {
            "slot": {
              "type": "string"
            },
            "type": {
              "anyOf": [
                {
                  "const": "hard_block",
                  "type": "string"
                },
                {
                  "const": "soft_block",
                  "type": "string"
                }
              ]
            },
            "question": {
              "type": "string"
            }
          }
        }
      ]
    },
    "history": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "answer_ref",
          "slots_updated"
        ],
        "properties": {
          "answer_ref": {
            "type": "string"
          },
          "slots_updated": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
