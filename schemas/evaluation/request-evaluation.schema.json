{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-img/schemas/request-evaluation.schema.json",
  "title": "Request evaluation",
  "description": "Output of the request-evaluation runbook (knowledge/reference/modes/request-evaluation.md) / request-evaluator agent. Classifies mode, required slots, blockers, and the next interview target.",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "detected_mode", "required_slots", "slot_states", "blockers", "ready", "next_interview_target"],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "raw_request": { "type": "string" },
    "detected_mode": {
      "type": "string",
      "enum": ["initial-setup", "data-collection", "image-generation", "performance-learning", "unknown"]
    },
    "mode_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "required_slots": { "type": "array", "items": { "type": "string" } },
    "slot_states": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "state"],
        "properties": {
          "name": { "type": "string" },
          "state": { "type": "string", "enum": ["missing", "insufficient", "filled", "confirmed"] }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slot", "type", "priority"],
        "properties": {
          "slot": { "type": "string" },
          "type": { "type": "string", "enum": ["hard_block", "soft_block"] },
          "priority": { "type": "integer", "minimum": 1 },
          "reason": { "type": "string" }
        }
      }
    },
    "ready": { "type": "boolean" },
    "next_interview_target": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["slot"],
          "properties": {
            "slot": { "type": "string" },
            "rationale": { "type": "string" }
          }
        }
      ]
    },
    "risk_flags": { "type": "array", "items": { "type": "string" } }
  }
}
