{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/request-evaluation.schema.json",
  "title": "Request evaluation",
  "description": "classifies mode, required slots, blockers, ready, and the next interview target",
  "type": "object",
  "required": [
    "run_id",
    "detected_mode",
    "required_slots",
    "slot_states",
    "blockers",
    "ready",
    "next_interview_target"
  ],
  "properties": {
    "run_id": {
      "minLength": 1,
      "type": "string"
    },
    "raw_request": {
      "type": "string"
    },
    "detected_mode": {
      "anyOf": [
        {
          "const": "initial-setup",
          "type": "string"
        },
        {
          "const": "data-collection",
          "type": "string"
        },
        {
          "const": "competitive-report",
          "type": "string"
        },
        {
          "const": "validate-recipe",
          "type": "string"
        },
        {
          "const": "image-generation",
          "type": "string"
        },
        {
          "const": "performance-learning",
          "type": "string"
        },
        {
          "const": "unknown",
          "type": "string"
        }
      ]
    },
    "mode_confidence": {
      "minimum": 0,
      "maximum": 1,
      "description": "<0.6 (with a risk_flag) when the call is uncertain",
      "type": "number"
    },
    "required_slots": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "slot_states": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "name",
          "state"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "state": {
            "anyOf": [
              {
                "const": "missing",
                "type": "string"
              },
              {
                "const": "insufficient",
                "type": "string"
              },
              {
                "const": "filled",
                "type": "string"
              },
              {
                "const": "confirmed",
                "type": "string"
              }
            ]
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "slot",
          "type",
          "priority"
        ],
        "properties": {
          "slot": {
            "type": "string"
          },
          "type": {
            "anyOf": [
              {
                "const": "hard_block",
                "type": "string"
              },
              {
                "const": "soft_block",
                "type": "string"
              }
            ]
          },
          "priority": {
            "minimum": 1,
            "type": "integer"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "ready": {
      "description": "true ⇔ zero hard_block remains (count, never assert)",
      "type": "boolean"
    },
    "next_interview_target": {
      "description": "null IFF ready; else the highest-priority HARD blocker",
      "anyOf": [
        {
          "type": "null"
        },
        {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "slot"
          ],
          "properties": {
            "slot": {
              "type": "string"
            },
            "rationale": {
              "type": "string"
            }
          }
        }
      ]
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
