{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-img/schemas/user-answer.schema.json",
  "title": "User answer artifact",
  "description": "Every interview answer becomes one of these. Raw text is preserved verbatim; normalized slot updates are derived. One answer may update multiple slots.",
  "type": "object",
  "additionalProperties": false,
  "required": ["answer_id", "run_id", "raw_answer", "for_blocker", "normalized_slot_updates"],
  "properties": {
    "answer_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "raw_answer": { "type": "string" },
    "for_blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot"],
      "properties": {
        "slot": { "type": "string" },
        "question": { "type": "string" }
      }
    },
    "normalized_slot_updates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slot", "value", "resulting_state"],
        "properties": {
          "slot": { "type": "string" },
          "value": {},
          "resulting_state": { "type": "string", "enum": ["missing", "insufficient", "filled", "confirmed"] },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
