{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/user-answer.schema.json",
  "title": "User answer artifact",
  "description": "an interview answer — raw text verbatim + derived normalized slot updates",
  "type": "object",
  "required": [
    "answer_id",
    "run_id",
    "raw_answer",
    "for_blocker",
    "normalized_slot_updates"
  ],
  "properties": {
    "answer_id": {
      "minLength": 1,
      "type": "string"
    },
    "run_id": {
      "minLength": 1,
      "type": "string"
    },
    "raw_answer": {
      "description": "preserved VERBATIM — never paraphrased",
      "type": "string"
    },
    "for_blocker": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "slot"
      ],
      "properties": {
        "slot": {
          "type": "string"
        },
        "question": {
          "type": "string"
        }
      }
    },
    "normalized_slot_updates": {
      "minItems": 1,
      "description": "one answer may update multiple slots",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "slot",
          "value",
          "resulting_state"
        ],
        "properties": {
          "slot": {
            "type": "string"
          },
          "value": {
            "description": "the structured value (any shape)"
          },
          "resulting_state": {
            "anyOf": [
              {
                "const": "missing",
                "type": "string"
              },
              {
                "const": "insufficient",
                "type": "string"
              },
              {
                "const": "filled",
                "type": "string"
              },
              {
                "const": "confirmed",
                "type": "string"
              }
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
