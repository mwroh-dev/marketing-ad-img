{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-img/schemas/keyword-instance.schema.json",
  "title": "KeywordInstances",
  "description": "ad-analyst output: extracted+normalized keyword instances (NOT ranked).",
  "type": "object",
  "additionalProperties": false,
  "required": ["product_id", "persona_id", "instances"],
  "properties": {
    "product_id": { "type": "string", "minLength": 1 },
    "persona_id": { "type": "string", "minLength": 1 },
    "source_competitors": { "type": "array", "items": { "type": "string" } },
    "instances": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["canonical", "slot"],
        "properties": {
          "canonical": { "type": "string", "minLength": 1 },
          "variants": { "type": "array", "items": { "type": "string" } },
          "slot": { "type": "string", "enum": ["product_category", "feature", "target", "benefit", "technique", "other"] },
          "english_origin": { "type": "boolean" }
        }
      }
    }
  }
}
