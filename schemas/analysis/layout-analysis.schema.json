{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/layout-analysis.schema.json",
  "title": "LayoutAnalysis",
  "description": "layout structure + comfort, derived from L1 geometry only",
  "type": "object",
  "required": [
    "image_ref",
    "persona_id",
    "composition_type",
    "text_density",
    "comfort"
  ],
  "properties": {
    "image_ref": {
      "minLength": 1,
      "type": "string"
    },
    "persona_id": {
      "minLength": 1,
      "type": "string"
    },
    "composition_type": {
      "description": "from GEOMETRY (bbox grid/placement/size), never from what the text says",
      "anyOf": [
        {
          "const": "product_only",
          "type": "string"
        },
        {
          "const": "lifestyle",
          "type": "string"
        },
        {
          "const": "comparison_table",
          "type": "string"
        },
        {
          "const": "review_capture",
          "type": "string"
        },
        {
          "const": "spec_list",
          "type": "string"
        },
        {
          "const": "usage",
          "type": "string"
        },
        {
          "const": "price_emphasis",
          "type": "string"
        },
        {
          "const": "other",
          "type": "string"
        }
      ]
    },
    "focal_point": {
      "description": "the single highest visual-weight element (bbox area × size rank), named by geometry/position",
      "type": "string"
    },
    "visual_hierarchy": {
      "description": "elements ordered by descending geometric weight (size+position)",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "text_density": {
      "description": "summed text-bbox coverage + element count, not semantic heaviness",
      "anyOf": [
        {
          "const": "low",
          "type": "string"
        },
        {
          "const": "medium",
          "type": "string"
        },
        {
          "const": "high",
          "type": "string"
        }
      ]
    },
    "whitespace_ratio": {
      "description": "1 − (element-bbox union / canvas), in [0,1]",
      "type": "number"
    },
    "comfort": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "crowding",
        "awkward_placement",
        "breathing_room"
      ],
      "properties": {
        "crowding": {
          "description": "spacing density from geometry (min gaps, element count, edge proximity, overlaps); higher = more cramped — relative within this persona's ads, not an absolute threshold",
          "type": "number"
        },
        "awkward_placement": {
          "description": "geometric: edge-cut / off-grid float / focal in a corner / misalignment",
          "type": "boolean"
        },
        "breathing_room": {
          "description": "healthy whitespace + low crowding (must be consistent with crowding)",
          "type": "boolean"
        },
        "balance": {
          "description": "weight distribution: symmetric / left-heavy / top-heavy / asymmetric",
          "type": "string"
        }
      }
    },
    "grid_pattern": {
      "type": "string"
    },
    "confidence": {
      "description": "read confidence — trust the layout read or escalate from the schema alone",
      "anyOf": [
        {
          "const": "high",
          "type": "string"
        },
        {
          "const": "medium",
          "type": "string"
        },
        {
          "const": "low",
          "type": "string"
        }
      ]
    }
  }
}
