{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-img/schemas/copy-analysis.schema.json",
  "title": "CopyAnalysis",
  "description": "L2b — text-role + hook + keywords, from L1 text content only.",
  "type": "object",
  "additionalProperties": false,
  "required": ["image_ref", "persona_id", "copy_elements"],
  "properties": {
    "image_ref": { "type": "string", "minLength": 1 },
    "persona_id": { "type": "string", "minLength": 1 },
    "copy_elements": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["content", "text_role"],
        "properties": {
          "content": { "type": "string" },
          "text_role": { "type": "string", "enum": ["headline", "subcopy", "CTA", "badge", "price", "review_quote", "spec_label", "other"] },
          "hook_type": { "type": "string", "enum": ["question", "contrast", "result", "empathy", "number", "other"] }
        }
      }
    },
    "sentence_patterns": { "type": "string" },
    "keywords": { "type": "array", "items": { "type": "string" } }
  }
}
