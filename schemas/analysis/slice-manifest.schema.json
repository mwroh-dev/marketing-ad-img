{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/slice-manifest.schema.json",
  "title": "SliceManifest",
  "description": "collection slicer output — long image → section mapping with source provenance",
  "type": "object",
  "required": [
    "sliced",
    "passthrough"
  ],
  "properties": {
    "sliced": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "source",
          "sections"
        ],
        "properties": {
          "source": {
            "type": "string"
          },
          "sections": {
            "type": "array",
            "items": {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "file",
                "y0",
                "y1"
              ],
              "properties": {
                "file": {
                  "type": "string"
                },
                "y0": {
                  "minimum": 0,
                  "type": "integer"
                },
                "y1": {
                  "minimum": 0,
                  "type": "integer"
                }
              }
            }
          }
        }
      }
    },
    "passthrough": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
