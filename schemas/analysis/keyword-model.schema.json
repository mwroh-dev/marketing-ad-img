{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/keyword-model.schema.json",
  "title": "KeywordModel",
  "description": "per-persona keyword model: functional-slot groups with deterministic top-k ranking",
  "type": "object",
  "required": [
    "product_id",
    "persona_id",
    "corpus",
    "weights",
    "groups"
  ],
  "properties": {
    "product_id": {
      "minLength": 1,
      "type": "string"
    },
    "persona_id": {
      "minLength": 1,
      "type": "string"
    },
    "corpus": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "competitor_count",
        "source"
      ],
      "properties": {
        "competitor_count": {
          "minimum": 0,
          "type": "integer"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "weights": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "tf",
        "df",
        "cue"
      ],
      "properties": {
        "tf": {
          "type": "number"
        },
        "df": {
          "type": "number"
        },
        "cue": {
          "type": "number"
        }
      }
    },
    "groups": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "slot",
          "keywords"
        ],
        "properties": {
          "slot": {
            "anyOf": [
              {
                "const": "product_category",
                "type": "string"
              },
              {
                "const": "feature",
                "type": "string"
              },
              {
                "const": "target",
                "type": "string"
              },
              {
                "const": "benefit",
                "type": "string"
              },
              {
                "const": "technique",
                "type": "string"
              },
              {
                "const": "other",
                "type": "string"
              }
            ]
          },
          "keywords": {
            "type": "array",
            "items": {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "canonical",
                "slot",
                "tf",
                "df",
                "score"
              ],
              "properties": {
                "canonical": {
                  "minLength": 1,
                  "type": "string"
                },
                "variants": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "slot": {
                  "anyOf": [
                    {
                      "const": "product_category",
                      "type": "string"
                    },
                    {
                      "const": "feature",
                      "type": "string"
                    },
                    {
                      "const": "target",
                      "type": "string"
                    },
                    {
                      "const": "benefit",
                      "type": "string"
                    },
                    {
                      "const": "technique",
                      "type": "string"
                    },
                    {
                      "const": "other",
                      "type": "string"
                    }
                  ]
                },
                "english_origin": {
                  "type": "boolean"
                },
                "tf": {
                  "type": "number"
                },
                "df": {
                  "type": "number"
                },
                "cue_match": {
                  "type": "number"
                },
                "score": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    },
    "generated_at": {
      "type": "string"
    },
    "confidence_note": {
      "type": "string"
    }
  }
}
