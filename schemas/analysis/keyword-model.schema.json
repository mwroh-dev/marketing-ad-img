{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-img/schemas/keyword-model.schema.json",
  "title": "KeywordModel",
  "description": "Per-persona keyword model: functional-slot groups with deterministic top-k ranking.",
  "type": "object",
  "additionalProperties": false,
  "required": ["product_id", "persona_id", "corpus", "weights", "groups"],
  "properties": {
    "product_id": { "type": "string", "minLength": 1 },
    "persona_id": { "type": "string", "minLength": 1 },
    "corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["competitor_count", "source"],
      "properties": {
        "competitor_count": { "type": "integer", "minimum": 0 },
        "source": { "type": "string" }
      }
    },
    "weights": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tf", "df", "cue"],
      "properties": { "tf": { "type": "number" }, "df": { "type": "number" }, "cue": { "type": "number" } }
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slot", "keywords"],
        "properties": {
          "slot": { "type": "string", "enum": ["product_category", "feature", "target", "benefit", "technique", "other"] },
          "keywords": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["canonical", "slot", "tf", "df", "score"],
              "properties": {
                "canonical": { "type": "string", "minLength": 1 },
                "variants": { "type": "array", "items": { "type": "string" } },
                "slot": { "type": "string", "enum": ["product_category", "feature", "target", "benefit", "technique", "other"] },
                "english_origin": { "type": "boolean" },
                "tf": { "type": "number" },
                "df": { "type": "number" },
                "cue_match": { "type": "number" },
                "score": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "generated_at": { "type": "string" },
    "confidence_note": { "type": "string" }
  }
}
