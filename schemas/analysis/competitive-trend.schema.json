{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/competitive-trend.schema.json",
  "title": "CompetitiveTrend",
  "description": "per-persona competitive trend across dated snapshots (longevity + variation + change); temporal fields omitted when unsupported",
  "type": "object",
  "required": [
    "persona_id",
    "snapshot_count",
    "dated_snapshot_count",
    "total_creatives",
    "tracked_ads",
    "ads",
    "longevity_top_k",
    "advertisers",
    "coverage_flags"
  ],
  "properties": {
    "persona_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "snapshot_count": {
      "minimum": 0,
      "description": "total snapshots aggregated (dated + undated)",
      "type": "integer"
    },
    "dated_snapshot_count": {
      "minimum": 0,
      "description": "subset with a parseable captured_at — change-over-time needs ≥2",
      "type": "integer"
    },
    "total_creatives": {
      "minimum": 0,
      "type": "integer"
    },
    "tracked_ads": {
      "minimum": 0,
      "description": "distinct ads tracked by library_id",
      "type": "integer"
    },
    "ads": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "library_id"
        ],
        "properties": {
          "library_id": {
            "minLength": 1,
            "type": "string"
          },
          "advertiser_name": {
            "type": "string"
          },
          "started_at": {
            "type": "string"
          },
          "running_days": {
            "minimum": 0,
            "description": "today − started_at; present only when started_at was captured",
            "type": "integer"
          },
          "platforms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "subtype": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "still_present": {
            "description": "appeared in the most recent dated snapshot; present only when seen in ≥1 dated snapshot",
            "type": "boolean"
          },
          "observed_span_days": {
            "minimum": 0,
            "description": "last_seen − first_seen; present only when the ad spans ≥2 dated snapshots",
            "type": "integer"
          }
        }
      }
    },
    "longevity_top_k": {
      "description": "ads with started_at ranked by running_days desc (longevity = winner proxy); ads lacking started_at are excluded, not zero-ranked",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "library_id",
          "running_days"
        ],
        "properties": {
          "library_id": {
            "type": "string"
          },
          "running_days": {
            "minimum": 0,
            "type": "integer"
          },
          "advertiser_name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      }
    },
    "advertisers": {
      "description": "per-advertiser creative variation (distinct ads) — available from a single snapshot",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "advertiser_name",
          "variation_count"
        ],
        "properties": {
          "advertiser_name": {
            "minLength": 1,
            "type": "string"
          },
          "variation_count": {
            "minimum": 0,
            "type": "integer"
          },
          "platform_mix": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "new_since_last": {
      "description": "library_ids in the latest dated snapshot but not the previous; ABSENT (not []) when <2 dated snapshots",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "disappeared_since_last": {
      "description": "library_ids in the previous but gone from the latest; absent when <2 dated snapshots",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cadence_new_ads_per_week": {
      "minimum": 0,
      "description": "new distinct ads per week; absent when <2 dated snapshots or zero span",
      "type": "number"
    },
    "today": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "coverage_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "synthesis": {
      "description": "Korean interpretive narrative competitive-analyst adds ON TOP of the numbers (recomputes nothing)",
      "type": "string"
    },
    "confidence_note": {
      "type": "string"
    }
  }
}
