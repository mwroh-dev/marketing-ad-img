{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/market-position-matrix.schema.json",
  "title": "MarketPositionMatrix",
  "description": "per-persona benefit×funnel positioning matrix (observed prevalence, not performance); whitespace = low frequency",
  "type": "object",
  "required": [
    "persona_id",
    "total_ads",
    "by_benefit_and_funnel"
  ],
  "properties": {
    "persona_id": {
      "minLength": 1,
      "type": "string"
    },
    "total_ads": {
      "minimum": 0,
      "type": "integer"
    },
    "by_benefit_and_funnel": {
      "additionalProperties": false,
      "description": "FULL benefit×funnel grid — 0 cells ARE the whitespace signal (counts = observed prevalence, NOT performance)",
      "type": "object",
      "required": [
        "function",
        "cost",
        "trust",
        "symbol",
        "unclear"
      ],
      "properties": {
        "function": {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "discovery",
            "comparison",
            "action",
            "retention",
            "unclear"
          ],
          "properties": {
            "discovery": {
              "minimum": 0,
              "type": "integer"
            },
            "comparison": {
              "minimum": 0,
              "type": "integer"
            },
            "action": {
              "minimum": 0,
              "type": "integer"
            },
            "retention": {
              "minimum": 0,
              "type": "integer"
            },
            "unclear": {
              "minimum": 0,
              "type": "integer"
            }
          }
        },
        "cost": {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "discovery",
            "comparison",
            "action",
            "retention",
            "unclear"
          ],
          "properties": {
            "discovery": {
              "minimum": 0,
              "type": "integer"
            },
            "comparison": {
              "minimum": 0,
              "type": "integer"
            },
            "action": {
              "minimum": 0,
              "type": "integer"
            },
            "retention": {
              "minimum": 0,
              "type": "integer"
            },
            "unclear": {
              "minimum": 0,
              "type": "integer"
            }
          }
        },
        "trust": {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "discovery",
            "comparison",
            "action",
            "retention",
            "unclear"
          ],
          "properties": {
            "discovery": {
              "minimum": 0,
              "type": "integer"
            },
            "comparison": {
              "minimum": 0,
              "type": "integer"
            },
            "action": {
              "minimum": 0,
              "type": "integer"
            },
            "retention": {
              "minimum": 0,
              "type": "integer"
            },
            "unclear": {
              "minimum": 0,
              "type": "integer"
            }
          }
        },
        "symbol": {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "discovery",
            "comparison",
            "action",
            "retention",
            "unclear"
          ],
          "properties": {
            "discovery": {
              "minimum": 0,
              "type": "integer"
            },
            "comparison": {
              "minimum": 0,
              "type": "integer"
            },
            "action": {
              "minimum": 0,
              "type": "integer"
            },
            "retention": {
              "minimum": 0,
              "type": "integer"
            },
            "unclear": {
              "minimum": 0,
              "type": "integer"
            }
          }
        },
        "unclear": {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "discovery",
            "comparison",
            "action",
            "retention",
            "unclear"
          ],
          "properties": {
            "discovery": {
              "minimum": 0,
              "type": "integer"
            },
            "comparison": {
              "minimum": 0,
              "type": "integer"
            },
            "action": {
              "minimum": 0,
              "type": "integer"
            },
            "retention": {
              "minimum": 0,
              "type": "integer"
            },
            "unclear": {
              "minimum": 0,
              "type": "integer"
            }
          }
        }
      }
    },
    "dominant_positions": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "position",
          "count",
          "share"
        ],
        "properties": {
          "position": {
            "type": "string"
          },
          "count": {
            "minimum": 0,
            "type": "integer"
          },
          "share": {
            "type": "number"
          },
          "common_ad_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "common_execution_styles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "common_devices": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "crowded_positions": {
      "description": "high observed frequency",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "position",
          "reason"
        ],
        "properties": {
          "position": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "whitespace_positions": {
      "description": "low observed frequency — a GAP, not a guaranteed opportunity",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "position",
          "reason"
        ],
        "properties": {
          "position": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "high_reusability_patterns": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "position"
        ],
        "properties": {
          "position": {
            "type": "string"
          },
          "devices": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "why_reusable": {
            "type": "string"
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "risk",
          "reason"
        ],
        "properties": {
          "risk": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "coverage_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generated_at": {
      "type": "string"
    }
  }
}
