{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/analyses-envelope.schema.json",
  "title": "AnalysesEnvelope",
  "description": "copy/layout output envelope — {persona_id, analyses[]}; each item validated separately",
  "type": "object",
  "required": [
    "persona_id",
    "analyses"
  ],
  "properties": {
    "persona_id": {
      "minLength": 1,
      "type": "string"
    },
    "analyses": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "image_ref",
          "persona_id"
        ],
        "properties": {
          "image_ref": {
            "type": "string"
          },
          "persona_id": {
            "type": "string"
          }
        }
      }
    }
  }
}
