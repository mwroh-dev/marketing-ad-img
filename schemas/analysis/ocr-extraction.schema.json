{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-img/schemas/ocr-extraction.schema.json",
  "title": "OcrExtraction",
  "description": "L1 mechanical extraction of one ad image. Standardized geometry+text — NO interpretation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["image_ref", "persona_id", "canvas", "text_elements", "graphic_elements"],
  "properties": {
    "image_ref": { "type": "string", "minLength": 1 },
    "persona_id": { "type": "string", "minLength": 1 },
    "competitor_id": { "type": "string" },
    "canvas": {
      "type": "object", "additionalProperties": false,
      "required": ["aspect_ratio"],
      "properties": {
        "aspect_ratio": { "type": "string" },
        "dominant_colors": { "type": "array", "items": { "type": "string" } },
        "background_desc": { "type": "string" }
      }
    },
    "text_elements": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["content", "bbox", "font_size_scale"],
        "properties": {
          "id": { "type": "string" },
          "content": { "type": "string" },
          "bbox": {
            "type": "object", "additionalProperties": false,
            "required": ["x", "y", "w", "h"],
            "properties": { "x": { "type": "number" }, "y": { "type": "number" }, "w": { "type": "number" }, "h": { "type": "number" } }
          },
          "font_size_scale": { "type": "string", "enum": ["xs", "s", "m", "l", "xl"] },
          "color_hex": { "type": "string" },
          "bold": { "type": "boolean" },
          "shadow": { "type": "boolean" },
          "align": { "type": "string", "enum": ["left", "center", "right"] },
          "line_breaks": { "type": "number" }
        }
      }
    },
    "graphic_elements": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["kind", "bbox"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string", "enum": ["product", "lifestyle", "icon", "badge", "chart", "other"] },
          "bbox": {
            "type": "object", "additionalProperties": false,
            "required": ["x", "y", "w", "h"],
            "properties": { "x": { "type": "number" }, "y": { "type": "number" }, "w": { "type": "number" }, "h": { "type": "number" } }
          },
          "border": { "type": "string", "enum": ["none", "line", "rounded", "shadow", "frame"] },
          "placement": { "type": "string" }
        }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
