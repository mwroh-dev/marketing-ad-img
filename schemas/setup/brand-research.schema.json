{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/brand-research.schema.json",
  "title": "BrandResearchFindings",
  "description": "one brand-researcher angle — public-source evidence + data-derived candidates",
  "type": "object",
  "required": [
    "brand_id",
    "angle",
    "sources_consulted",
    "evidence"
  ],
  "properties": {
    "brand_id": {
      "minLength": 1,
      "type": "string"
    },
    "angle": {
      "description": "which research lens this artifact covers",
      "anyOf": [
        {
          "const": "page",
          "type": "string"
        },
        {
          "const": "reviews",
          "type": "string"
        },
        {
          "const": "positioning",
          "type": "string"
        }
      ]
    },
    "sources_consulted": {
      "description": "every public source actually fetched/searched (honest)",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "ref",
          "method"
        ],
        "properties": {
          "ref": {
            "minLength": 1,
            "description": "URL or search query actually used",
            "type": "string"
          },
          "method": {
            "anyOf": [
              {
                "const": "curl",
                "type": "string"
              },
              {
                "const": "webfetch",
                "type": "string"
              },
              {
                "const": "websearch",
                "type": "string"
              },
              {
                "const": "cdp",
                "type": "string"
              }
            ]
          },
          "reached": {
            "description": "false if blocked/unreachable",
            "type": "boolean"
          }
        }
      }
    },
    "evidence": {
      "description": "concrete observations — facts, not interpretation; each candidate traces here",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "observation",
          "source_ref"
        ],
        "properties": {
          "observation": {
            "minLength": 1,
            "type": "string"
          },
          "source_ref": {
            "minLength": 1,
            "description": "which sources_consulted[].ref this came from",
            "type": "string"
          }
        }
      }
    },
    "category_candidates": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "category",
          "evidence_refs"
        ],
        "properties": {
          "category": {
            "minLength": 1,
            "type": "string"
          },
          "evidence_refs": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "persona_candidates": {
      "description": "data-derived persona options for the interview to present as CHOICES",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "label",
          "who",
          "evidence_refs"
        ],
        "properties": {
          "label": {
            "minLength": 1,
            "type": "string"
          },
          "who": {
            "minLength": 1,
            "description": "who this buyer is, in plain terms",
            "type": "string"
          },
          "pains": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "desires": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_refs": {
            "minItems": 1,
            "description": "review/page observations grounding this persona — no fabrication",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "positioning_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_claim_risks": {
      "description": "claims observed that may be over-claims to guard downstream",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "coverage_flags": {
      "description": "what could NOT be reached/found — honest gaps",
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
