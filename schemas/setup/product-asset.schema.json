{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/product-asset.schema.json",
  "title": "Product asset",
  "description": "raw + cutout product image refs + cleanup status (cutout may not exist yet)",
  "type": "object",
  "required": [
    "asset_id",
    "product_id",
    "raw_image_path",
    "cutout_status"
  ],
  "properties": {
    "asset_id": {
      "minLength": 1,
      "type": "string"
    },
    "product_id": {
      "minLength": 1,
      "type": "string"
    },
    "raw_image_path": {
      "type": "string"
    },
    "cutout_path": {
      "type": "string"
    },
    "preview_path": {
      "type": "string"
    },
    "mask_path": {
      "type": "string"
    },
    "cutout_status": {
      "anyOf": [
        {
          "const": "missing",
          "type": "string"
        },
        {
          "const": "pending",
          "type": "string"
        },
        {
          "const": "passed",
          "type": "string"
        },
        {
          "const": "failed",
          "type": "string"
        }
      ]
    },
    "cleanup_report_ref": {
      "type": "string"
    }
  }
}
