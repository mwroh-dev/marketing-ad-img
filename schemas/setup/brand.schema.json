{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/brand.schema.json",
  "title": "Brand",
  "description": "domain knowledge: a brand (has many products)",
  "type": "object",
  "required": [
    "brand_id",
    "brand_name",
    "brand_goal",
    "product_ids"
  ],
  "properties": {
    "brand_id": {
      "minLength": 1,
      "type": "string"
    },
    "brand_name": {
      "minLength": 1,
      "type": "string"
    },
    "brand_goal": {
      "type": "string"
    },
    "target_market": {
      "additionalProperties": false,
      "description": "WHERE the seller sells — scopes ad/competitor/research queries to the right market+language",
      "type": "object",
      "properties": {
        "scope": {
          "anyOf": [
            {
              "const": "domestic",
              "type": "string"
            },
            {
              "const": "overseas",
              "type": "string"
            },
            {
              "const": "both",
              "type": "string"
            }
          ]
        },
        "regions": {
          "description": "country/locale codes, e.g. KR/US/JP",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "languages": {
          "description": "ad copy languages, e.g. ko/en",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "positioning": {
      "type": "string"
    },
    "tone": {
      "type": "string"
    },
    "forbidden_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "product_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
