{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-img/schemas/ad-creative.schema.json",
  "title": "AdCreativeSet",
  "description": "Per-persona set of real ad creatives collected from a public ad library. Feeds ad analysis analysis.",
  "type": "object",
  "additionalProperties": false,
  "required": ["persona_id", "source", "search", "creatives"],
  "properties": {
    "persona_id": { "type": "string", "minLength": 1 },
    "product_id": { "type": "string" },
    "advertiser": { "type": "string" },
    "source": { "type": "string", "enum": ["meta_ad_library", "google_ads_transparency", "tiktok_creative_center", "own_detail_cut"] },
    "search": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "query"],
      "properties": {
        "mode": { "type": "string", "enum": ["advertiser", "keyword", "detail_cut"] },
        "query": { "type": "string" },
        "category": { "type": "string" },
        "country": { "type": "string" }
      }
    },
    "creatives": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["image_url", "subtype"],
        "properties": {
          "library_id": { "type": "string" },
          "image_url": { "type": "string" },
          "image_file": { "type": "string" },
          "ad_copy": { "type": "string" },
          "platforms": { "type": "array", "items": { "type": "string" } },
          "started_at": { "type": "string" },
          "subtype": { "type": "string", "enum": ["single_image", "carousel", "video_thumb"] },
          "advertiser_id": { "type": "string" },
          "resolved_via": { "type": "string", "enum": ["advertiser", "advertiser_loose", "text_fallback"] },
          "matched_name": { "type": "string" },
          "match_quality": { "type": "string", "enum": ["exact", "prefix", "loose"] },
          "type": { "type": "string", "enum": ["ad_creative", "catalog", "spec", "review", "lifestyle", "unknown"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "competitor_id": { "type": "string" }
        }
      }
    },
    "queries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mode", "query"],
        "properties": {
          "mode": { "type": "string", "enum": ["advertiser", "keyword"] },
          "query": { "type": "string" }
        }
      }
    },
    "coverage_flags": { "type": "array", "items": { "type": "string" } },
    "blocked": { "type": "boolean" },
    "captured_at": { "type": "string" }
  }
}
