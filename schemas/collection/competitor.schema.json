{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/competitor.schema.json",
  "title": "CompetitorSet",
  "description": "confirmed per-persona competitor set (domain knowledge)",
  "type": "object",
  "required": [
    "product_id",
    "persona_id",
    "competitors"
  ],
  "properties": {
    "product_id": {
      "minLength": 1,
      "type": "string"
    },
    "persona_id": {
      "minLength": 1,
      "type": "string"
    },
    "relevance_criteria": {
      "type": "string"
    },
    "competitors": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "competitor_id",
          "name",
          "status"
        ],
        "properties": {
          "competitor_id": {
            "minLength": 1,
            "type": "string"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "seller": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "source_surface": {
            "anyOf": [
              {
                "const": "meta_ad_library",
                "type": "string"
              },
              {
                "const": "google_ads_transparency",
                "type": "string"
              }
            ]
          },
          "rationale": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_target_ref": {
            "type": "string"
          },
          "status": {
            "description": "confirmed only after explicit user sign-off (HARD GATE)",
            "anyOf": [
              {
                "const": "proposed",
                "type": "string"
              },
              {
                "const": "confirmed",
                "type": "string"
              },
              {
                "const": "rejected",
                "type": "string"
              }
            ]
          }
        }
      }
    },
    "confirmed_at": {
      "type": "string"
    },
    "rejected_note": {
      "type": "string"
    }
  }
}
