{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/competitor-candidate.schema.json",
  "title": "CompetitorCandidatePool",
  "description": "discovery-scout broad candidate pool (search/list only, recall-max)",
  "type": "object",
  "required": [
    "product_id",
    "persona_id",
    "source_surfaces",
    "candidates"
  ],
  "properties": {
    "product_id": {
      "minLength": 1,
      "type": "string"
    },
    "persona_id": {
      "minLength": 1,
      "type": "string"
    },
    "seeds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_surfaces": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "const": "meta_ad_library",
            "type": "string"
          },
          {
            "const": "google_ads_transparency",
            "type": "string"
          }
        ]
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "name",
          "source_surface"
        ],
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "seller": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "snippet": {
            "type": "string"
          },
          "source_surface": {
            "anyOf": [
              {
                "const": "meta_ad_library",
                "type": "string"
              },
              {
                "const": "google_ads_transparency",
                "type": "string"
              }
            ]
          },
          "why_surfaced": {
            "type": "string"
          },
          "persona_fit_score": {
            "description": "optional curator hint — NEVER a discovery cutoff",
            "type": "number"
          },
          "is_seed": {
            "type": "boolean"
          }
        }
      }
    },
    "coverage_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_surfaces": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "captured_at": {
      "type": "string"
    }
  }
}
