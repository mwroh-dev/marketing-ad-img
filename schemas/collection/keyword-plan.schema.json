{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/keyword-plan.schema.json",
  "title": "KeywordPlan",
  "description": "pre-collection 3-axis (Needs/Use-case/Adjacency) keyword expansion for coverage",
  "type": "object",
  "required": [
    "product_id",
    "persona_id",
    "target_market",
    "axes",
    "queries"
  ],
  "properties": {
    "product_id": {
      "minLength": 1,
      "type": "string"
    },
    "persona_id": {
      "minLength": 1,
      "type": "string"
    },
    "target_market": {
      "minLength": 1,
      "description": "language/market scope the queries are written for, e.g. KR",
      "type": "string"
    },
    "axes": {
      "additionalProperties": false,
      "description": "the three expansion axes (goal is COVERAGE, not precision)",
      "type": "object",
      "required": [
        "needs",
        "use_case",
        "adjacency"
      ],
      "properties": {
        "needs": {
          "description": "Needs — the underlying job/desire the buyer is solving",
          "type": "array",
          "items": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "term"
            ],
            "properties": {
              "term": {
                "minLength": 1,
                "type": "string"
              },
              "rationale": {
                "description": "one line: why this term belongs to this axis",
                "type": "string"
              }
            }
          }
        },
        "use_case": {
          "description": "Use-case — when/where the behavior happens (occasion/scene)",
          "type": "array",
          "items": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "term"
            ],
            "properties": {
              "term": {
                "minLength": 1,
                "type": "string"
              },
              "rationale": {
                "description": "one line: why this term belongs to this axis",
                "type": "string"
              }
            }
          }
        },
        "adjacency": {
          "description": "Adjacency — products the same buyer also seeks (concrete co-sought nouns)",
          "type": "array",
          "items": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "term"
            ],
            "properties": {
              "term": {
                "minLength": 1,
                "type": "string"
              },
              "rationale": {
                "description": "one line: why this term belongs to this axis",
                "type": "string"
              }
            }
          }
        }
      }
    },
    "queries": {
      "minItems": 1,
      "description": "flattened search queries — every query traces to an axis",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "query",
          "mode",
          "axis"
        ],
        "properties": {
          "query": {
            "minLength": 1,
            "description": "the actual search string for Meta keyword search",
            "type": "string"
          },
          "mode": {
            "const": "keyword",
            "type": "string"
          },
          "axis": {
            "anyOf": [
              {
                "const": "needs",
                "type": "string"
              },
              {
                "const": "use_case",
                "type": "string"
              },
              {
                "const": "adjacency",
                "type": "string"
              }
            ]
          }
        }
      }
    }
  }
}
