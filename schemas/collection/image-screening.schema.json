{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/image-screening.schema.json",
  "title": "ImageScreening",
  "description": "collection→analysis keep/drop gate; every collected image accounted for",
  "type": "object",
  "required": [
    "run_id",
    "persona_id",
    "total",
    "kept",
    "dropped"
  ],
  "properties": {
    "run_id": {
      "minLength": 1,
      "type": "string"
    },
    "persona_id": {
      "minLength": 1,
      "type": "string"
    },
    "total": {
      "minimum": 0,
      "description": "must equal kept.length + dropped.length — no silent omission",
      "type": "integer"
    },
    "kept": {
      "description": "image_file paths that proceed to analysis",
      "type": "array",
      "items": {
        "minLength": 1,
        "type": "string"
      }
    },
    "dropped": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "image_file",
          "reason"
        ],
        "properties": {
          "image_file": {
            "minLength": 1,
            "type": "string"
          },
          "reason": {
            "anyOf": [
              {
                "const": "user_removed",
                "type": "string"
              },
              {
                "const": "logo_only",
                "type": "string"
              },
              {
                "const": "ui_or_screenshot",
                "type": "string"
              },
              {
                "const": "unrelated",
                "type": "string"
              },
              {
                "const": "broken_or_empty",
                "type": "string"
              },
              {
                "const": "duplicate",
                "type": "string"
              },
              {
                "const": "no_ad_content",
                "type": "string"
              },
              {
                "const": "unreadable",
                "type": "string"
              }
            ]
          }
        }
      }
    }
  }
}
