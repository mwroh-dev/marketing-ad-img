{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/run-manifest.schema.json",
  "title": "RunManifest",
  "description": "per-run progress ledger — dated identity + monotonic stage (collected→human_reviewed→screened→analyzed)",
  "type": "object",
  "required": [
    "run_id",
    "created_at",
    "source",
    "track",
    "persona_id",
    "queries",
    "stage",
    "counts"
  ],
  "properties": {
    "run_id": {
      "minLength": 1,
      "description": "dated id, e.g. 2026-06-23-1430-meta-keyword",
      "type": "string"
    },
    "created_at": {
      "minLength": 1,
      "description": "ISO-8601 run creation instant",
      "type": "string"
    },
    "source": {
      "minLength": 1,
      "description": "collection source, e.g. meta_ad_library | google_ads_transparency",
      "type": "string"
    },
    "track": {
      "description": "category_keyword = ad-corpus track; competitor = advertiser track",
      "anyOf": [
        {
          "const": "category_keyword",
          "type": "string"
        },
        {
          "const": "competitor",
          "type": "string"
        }
      ]
    },
    "persona_id": {
      "minLength": 1,
      "type": "string"
    },
    "product_id": {
      "description": "set when a keyword-plan carries it; null for a bare positional run",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "queries": {
      "description": "what was searched this run",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "query",
          "mode"
        ],
        "properties": {
          "query": {
            "minLength": 1,
            "type": "string"
          },
          "mode": {
            "anyOf": [
              {
                "const": "keyword",
                "type": "string"
              },
              {
                "const": "advertiser",
                "type": "string"
              }
            ]
          },
          "axis": {
            "description": "keyword-plan axis; advertiser for competitor queries; null for bare runs",
            "anyOf": [
              {
                "const": "needs",
                "type": "string"
              },
              {
                "const": "use_case",
                "type": "string"
              },
              {
                "const": "adjacency",
                "type": "string"
              },
              {
                "const": "advertiser",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "results_count": {
            "description": "platform-reported result count (coverage signal); null if not captured",
            "anyOf": [
              {
                "minimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      }
    },
    "stage": {
      "description": "current pipeline stage — advances monotonically",
      "anyOf": [
        {
          "const": "collected",
          "type": "string"
        },
        {
          "const": "human_reviewed",
          "type": "string"
        },
        {
          "const": "screened",
          "type": "string"
        },
        {
          "const": "analyzed",
          "type": "string"
        }
      ]
    },
    "counts": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "collected",
        "kept_by_human",
        "screened",
        "analyzed"
      ],
      "properties": {
        "collected": {
          "minimum": 0,
          "type": "integer"
        },
        "kept_by_human": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "screened": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "analyzed": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "stage_history": {
      "description": "append-only audit of stage transitions",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "stage",
          "at"
        ],
        "properties": {
          "stage": {
            "anyOf": [
              {
                "const": "collected",
                "type": "string"
              },
              {
                "const": "human_reviewed",
                "type": "string"
              },
              {
                "const": "screened",
                "type": "string"
              },
              {
                "const": "analyzed",
                "type": "string"
              }
            ]
          },
          "at": {
            "minLength": 1,
            "type": "string"
          }
        }
      }
    }
  }
}
