{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/competitor-collection.schema.json",
  "title": "CompetitorCollection",
  "description": "creatives collected from a public ad-transparency library (credential-free)",
  "type": "object",
  "required": [
    "from",
    "confirmed_targets",
    "source",
    "collected",
    "products",
    "captured_at"
  ],
  "properties": {
    "from": {
      "minLength": 1,
      "type": "string"
    },
    "confirmed_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source": {
      "minLength": 1,
      "type": "string"
    },
    "collected": {
      "minimum": 1,
      "type": "integer"
    },
    "products": {
      "minItems": 1,
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "idx",
          "query",
          "host",
          "title",
          "image_urls",
          "image_files",
          "reviews"
        ],
        "properties": {
          "idx": {
            "type": "integer"
          },
          "query": {
            "minLength": 1,
            "type": "string"
          },
          "host": {
            "minLength": 1,
            "type": "string"
          },
          "title": {
            "minLength": 1,
            "type": "string"
          },
          "price": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "rating": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "reviewCount": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "image_urls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "image_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "review_count_collected": {
            "type": "integer"
          },
          "reviews": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "captured_at": {
      "type": "string"
    }
  }
}
