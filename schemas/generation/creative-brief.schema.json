{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/creative-brief.schema.json",
  "title": "CreativeBrief",
  "description": "creative brief — core message, differentiation, 4 angles, forbidden-claim guards",
  "type": "object",
  "required": [
    "persona_id",
    "product_id",
    "core_message",
    "angles",
    "forbidden_claims"
  ],
  "properties": {
    "persona_id": {
      "minLength": 1,
      "type": "string"
    },
    "product_id": {
      "minLength": 1,
      "type": "string"
    },
    "core_message": {
      "minLength": 1,
      "description": "the single sharpest line; traces to a product claim ∧ a persona pain/desire",
      "type": "string"
    },
    "differentiation": {
      "type": "string"
    },
    "key_messages": {
      "type": "array",
      "items": {
        "additionalProperties": true,
        "type": "object",
        "properties": {}
      }
    },
    "angles": {
      "minItems": 1,
      "description": "the 4 enum angles, each a different lens on core_message (not 4 rewordings)",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "angle",
          "direction"
        ],
        "properties": {
          "angle": {
            "anyOf": [
              {
                "const": "product_usp",
                "type": "string"
              },
              {
                "const": "persona_response",
                "type": "string"
              },
              {
                "const": "compelling_claim",
                "type": "string"
              },
              {
                "const": "visual_hierarchy",
                "type": "string"
              }
            ]
          },
          "direction": {
            "description": "an actionable creative instruction, not a paraphrase of core_message",
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "forbidden_claims": {
      "description": "brand list verbatim ∪ derived-implicit; the hard guard the whole chain inherits",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "brand_tone": {
      "minLength": 1,
      "description": "the brand's voice (e.g. 'honest, energetic, not-luxury'); the adapter derives visual style from it, never premium-by-default",
      "type": "string"
    }
  }
}
