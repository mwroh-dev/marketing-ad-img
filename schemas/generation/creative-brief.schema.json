{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-img/schemas/creative-brief.schema.json",
  "title": "CreativeBrief",
  "description": "generation creative-brief output — core message, differentiation, 4 angles, and forbidden-claim guards.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "persona_id",
    "product_id",
    "core_message",
    "angles",
    "forbidden_claims"
  ],
  "properties": {
    "persona_id": {
      "type": "string",
      "minLength": 1
    },
    "product_id": {
      "type": "string",
      "minLength": 1
    },
    "core_message": {
      "type": "string",
      "minLength": 1
    },
    "differentiation": {
      "type": "string"
    },
    "key_messages": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "angles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "angle",
          "direction"
        ],
        "properties": {
          "angle": {
            "type": "string",
            "enum": [
              "product_usp",
              "persona_response",
              "compelling_claim",
              "visual_hierarchy"
            ]
          },
          "direction": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "forbidden_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "brand_tone": {
      "type": "string",
      "minLength": 1,
      "description": "the brand's voice (e.g. 'honest, energetic, not-luxury') — carried downstream so the adapter derives visual style from it, never a premium default"
    }
  }
}