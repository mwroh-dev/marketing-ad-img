{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-img/schemas/critic-verdict.schema.json",
  "title": "CriticVerdict",
  "description": "generation critic output — per-candidate PASS/FAIL + overall verdict.",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdicts", "overall_pass"],
  "properties": {
    "verdicts": { "type": "array", "minItems": 1, "items": {
      "type": "object", "additionalProperties": false, "required": ["candidate_id", "pass"],
      "properties": {
        "candidate_id": { "type": "string" },
        "pass": { "type": "boolean" },
        "issues": { "type": "array", "items": { "type": "string" } },
        "risk_flags": { "type": "array", "items": { "type": "string" } } } } },
    "overall_pass": { "type": "boolean" }
  }
}
