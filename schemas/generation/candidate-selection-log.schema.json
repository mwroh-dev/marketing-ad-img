{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/candidate-selection-log.schema.json",
  "title": "Candidate selection log",
  "description": "records why each candidate was generated (joinable by candidate_id)",
  "type": "object",
  "required": [
    "run_id",
    "candidate_count",
    "selection_strategy",
    "candidates"
  ],
  "properties": {
    "run_id": {
      "minLength": 1,
      "type": "string"
    },
    "candidate_count": {
      "minimum": 1,
      "maximum": 12,
      "type": "integer"
    },
    "selection_strategy": {
      "type": "string"
    },
    "candidates": {
      "minItems": 1,
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "candidate_id",
          "angle",
          "primary_variable",
          "product_id",
          "persona_id",
          "format",
          "reason"
        ],
        "properties": {
          "candidate_id": {
            "pattern": "^candidate_[0-9]{3}$",
            "type": "string"
          },
          "angle": {
            "type": "string"
          },
          "primary_variable": {
            "type": "string"
          },
          "product_id": {
            "type": "string"
          },
          "persona_id": {
            "type": "string"
          },
          "copy_strategy": {
            "type": "string"
          },
          "layout_strategy": {
            "type": "string"
          },
          "format": {
            "type": "string"
          },
          "adapter": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "minLength": 1,
            "type": "string"
          }
        }
      }
    }
  }
}
