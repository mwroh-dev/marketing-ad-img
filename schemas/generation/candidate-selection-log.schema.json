{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-img/schemas/candidate-selection-log.schema.json",
  "title": "Candidate selection log",
  "description": "Records why each candidate was generated. Structured so future performance-learning (backlog) can join campaign metrics by candidate_id.",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "candidate_count", "selection_strategy", "candidates"],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "candidate_count": { "type": "integer", "minimum": 1, "maximum": 12 },
    "selection_strategy": { "type": "string" },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "angle", "primary_variable", "product_id", "persona_id", "format", "reason"],
        "properties": {
          "candidate_id": { "type": "string", "pattern": "^candidate_[0-9]{3}$" },
          "angle": { "type": "string" },
          "primary_variable": { "type": "string" },
          "product_id": { "type": "string" },
          "persona_id": { "type": "string" },
          "copy_strategy": { "type": "string" },
          "layout_strategy": { "type": "string" },
          "format": { "type": "string" },
          "adapter": { "type": "array", "items": { "type": "string" } },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
