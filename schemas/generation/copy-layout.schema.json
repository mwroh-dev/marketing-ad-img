{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/copy-layout.schema.json",
  "title": "CopyLayoutPlan",
  "description": "per-candidate Korean copy + layout plan (copy authored once here)",
  "type": "object",
  "required": [
    "persona_id",
    "candidates"
  ],
  "properties": {
    "persona_id": {
      "minLength": 1,
      "type": "string"
    },
    "candidates": {
      "minItems": 1,
      "description": "one per brief angle, the four distinct (different hook/headline/focal)",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "angle",
          "headline",
          "cta",
          "layout"
        ],
        "properties": {
          "angle": {
            "anyOf": [
              {
                "const": "product_usp",
                "type": "string"
              },
              {
                "const": "persona_response",
                "type": "string"
              },
              {
                "const": "compelling_claim",
                "type": "string"
              },
              {
                "const": "visual_hierarchy",
                "type": "string"
              }
            ]
          },
          "headline": {
            "minLength": 1,
            "description": "final render-ready Korean, authored once (downstream preserves byte-for-byte)",
            "type": "string"
          },
          "subcopy": {
            "anyOf": [
              {
                "description": "one supporting line, or null when it earns nothing",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "cta": {
            "minLength": 1,
            "description": "short imperative Korean action phrase",
            "type": "string"
          },
          "layout": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "composition",
              "text_density"
            ],
            "properties": {
              "composition": {
                "description": "short frame description (e.g. 'product hero center, headline top-left')",
                "type": "string"
              },
              "text_density": {
                "description": "consistent with the angle (visual_hierarchy → low)",
                "anyOf": [
                  {
                    "const": "low",
                    "type": "string"
                  },
                  {
                    "const": "medium",
                    "type": "string"
                  },
                  {
                    "const": "high",
                    "type": "string"
                  }
                ]
              },
              "focal_point": {
                "type": "string"
              },
              "whitespace": {
                "type": "string"
              },
              "format": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "style": {
      "additionalProperties": false,
      "description": "brand voice carried from the brief — DRIVES the adapter's visual mood",
      "type": "object",
      "properties": {
        "brand_tone": {
          "minLength": 1,
          "description": "the brand's voice carried from the brief; the adapter derives mood from it, never premium-by-default",
          "type": "string"
        },
        "avoid": {
          "description": "visual/claim avoids pushed into the adapter negative_prompt",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
