{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-img/schemas/copy-layout.schema.json",
  "title": "CopyLayoutPlan",
  "description": "generation output — per-candidate Korean copy + layout plan.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "persona_id",
    "candidates"
  ],
  "properties": {
    "persona_id": {
      "type": "string",
      "minLength": 1
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "angle",
          "headline",
          "cta",
          "layout"
        ],
        "properties": {
          "angle": {
            "type": "string",
            "enum": [
              "product_usp",
              "persona_response",
              "compelling_claim",
              "visual_hierarchy"
            ]
          },
          "headline": {
            "type": "string",
            "minLength": 1
          },
          "subcopy": {
            "type": [
              "string",
              "null"
            ]
          },
          "cta": {
            "type": "string",
            "minLength": 1
          },
          "layout": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "composition",
              "text_density"
            ],
            "properties": {
              "composition": {
                "type": "string"
              },
              "text_density": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              },
              "focal_point": {
                "type": "string"
              },
              "whitespace": {
                "type": "string"
              },
              "format": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "description": "brand voice carried from the brief — DRIVES the adapter's visual mood. The adapter must derive style from brand_tone and NEVER default to premium/luxury.",
      "properties": {
        "brand_tone": {
          "type": "string",
          "minLength": 1,
          "description": "the brand's voice, e.g. 'honest, energetic, not-luxury' — never assumed premium"
        },
        "avoid": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "visual/claim avoids pushed into the adapter negative_prompt"
        }
      }
    }
  }
}