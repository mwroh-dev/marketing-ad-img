{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "$id": "https://marketing-img/schemas/image-adapter-output.schema.json",
  "title": "Image adapter output file",
  "description": "provider-specific prompt artifacts (prompt-only; no real provider call)",
  "type": "object",
  "required": [
    "adapter_id",
    "provider",
    "run_id",
    "outputs"
  ],
  "properties": {
    "adapter_id": {
      "anyOf": [
        {
          "const": "chatgpt_image",
          "type": "string"
        },
        {
          "const": "gemini_image",
          "type": "string"
        }
      ]
    },
    "provider": {
      "anyOf": [
        {
          "const": "chatgpt",
          "type": "string"
        },
        {
          "const": "gemini",
          "type": "string"
        }
      ]
    },
    "run_id": {
      "minLength": 1,
      "type": "string"
    },
    "outputs": {
      "minItems": 1,
      "description": "one per candidate",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "description": "the 9-field per-candidate provider output",
        "type": "object",
        "required": [
          "provider",
          "candidate_id",
          "prompt",
          "negative_prompt",
          "provider_notes",
          "input_assets",
          "expected_output",
          "verification_checklist",
          "retry_instruction_template"
        ],
        "properties": {
          "provider": {
            "anyOf": [
              {
                "const": "chatgpt",
                "type": "string"
              },
              {
                "const": "gemini",
                "type": "string"
              }
            ]
          },
          "candidate_id": {
            "pattern": "^candidate_[0-9]{3}$",
            "type": "string"
          },
          "prompt": {
            "minLength": 1,
            "type": "string"
          },
          "negative_prompt": {
            "type": "string"
          },
          "provider_notes": {
            "type": "string"
          },
          "input_assets": {
            "type": "array",
            "items": {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "asset_id",
                "role"
              ],
              "properties": {
                "asset_id": {
                  "type": "string"
                },
                "role": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                }
              }
            }
          },
          "expected_output": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "format",
              "ratio"
            ],
            "properties": {
              "format": {
                "type": "string"
              },
              "ratio": {
                "type": "string"
              },
              "width": {
                "type": "integer"
              },
              "height": {
                "type": "integer"
              }
            }
          },
          "verification_checklist": {
            "minItems": 1,
            "type": "array",
            "items": {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "check",
                "expected"
              ],
              "properties": {
                "check": {
                  "type": "string"
                },
                "expected": {
                  "description": "the literal copy string to verify — never a hollow 'headline correct'",
                  "type": "string"
                }
              }
            }
          },
          "retry_instruction_template": {
            "minLength": 1,
            "description": "with a placeholder for the specific failed check",
            "type": "string"
          }
        }
      }
    }
  }
}
