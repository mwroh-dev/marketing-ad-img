{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-img/schemas/image-adapter-output.schema.json",
  "title": "Image adapter output file",
  "description": "Provider-specific prompt artifacts. Written to .generate-ads-img/runs/{run_id}/generated-prompts/{provider}.json. Prompt-only; no real provider call.",
  "type": "object",
  "additionalProperties": false,
  "required": ["adapter_id", "provider", "run_id", "outputs"],
  "properties": {
    "adapter_id": { "type": "string", "enum": ["chatgpt_image", "gemini_image"] },
    "provider": { "type": "string", "enum": ["chatgpt", "gemini"] },
    "run_id": { "type": "string", "minLength": 1 },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/adapterOutput" }
    }
  },
  "$defs": {
    "adapterOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "candidate_id",
        "prompt",
        "negative_prompt",
        "provider_notes",
        "input_assets",
        "expected_output",
        "verification_checklist",
        "retry_instruction_template"
      ],
      "properties": {
        "provider": { "type": "string", "enum": ["chatgpt", "gemini"] },
        "candidate_id": { "type": "string", "pattern": "^candidate_[0-9]{3}$" },
        "prompt": { "type": "string", "minLength": 1 },
        "negative_prompt": { "type": "string" },
        "provider_notes": { "type": "string" },
        "input_assets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["asset_id", "role"],
            "properties": {
              "asset_id": { "type": "string" },
              "role": { "type": "string" },
              "path": { "type": "string" }
            }
          }
        },
        "expected_output": {
          "type": "object",
          "additionalProperties": false,
          "required": ["format", "ratio"],
          "properties": {
            "format": { "type": "string" },
            "ratio": { "type": "string" },
            "width": { "type": "integer" },
            "height": { "type": "integer" }
          }
        },
        "verification_checklist": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["check", "expected"],
            "properties": {
              "check": { "type": "string" },
              "expected": { "type": "string" }
            }
          }
        },
        "retry_instruction_template": { "type": "string", "minLength": 1 }
      }
    }
  }
}
